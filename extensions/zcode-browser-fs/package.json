{
  "name": "zcode-browser-fs",
  "displayName": "ZCode Browser FS",
  "description": "OPFS / virtual FileSystemProvider for ZCode browser mode",
  "version": "0.0.1",
  "publisher": "spinupdev",
  "private": true,
  "engines": {
    "vscode": "^1.129.0"
  },
  "categories": [
    "Other"
  ],
  "browser": "./dist/web/extension.js",
  "activationEvents": [
    "onFileSystem:zcode-opfs",
    "onCommand:zcode.fs.openWorkspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "zcode.fs.openWorkspace",
        "title": "ZCode: Open Virtual Workspace"
      }
    ]
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"process.exit(0)\"",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "typescript": "^5.8.3",
    "esbuild": "^0.25.5"
  }
}
