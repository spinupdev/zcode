{
  "name": "zcode-git",
  "displayName": "ZCode Git (Browser)",
  "description": "SCM + open/clone any HTTPS git repo via isomorphic-git and /git-proxy (browser mode)",
  "version": "0.3.0",
  "publisher": "spinupdev",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers"],
  "extensionKind": ["ui"],
  "browser": "./dist/web/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:zcode.git.clone",
    "onCommand:zcode.git.openRepository",
    "onCommand:zcode.git.commit",
    "onCommand:zcode.git.push",
    "onCommand:zcode.git.refresh",
    "onCommand:remoteHub.openRepository"
  ],
  "contributes": {
    "commands": [
      {
        "command": "zcode.git.openRepository",
        "title": "ZCode: Open Repository…",
        "icon": "$(repo-clone)"
      },
      {
        "command": "zcode.git.clone",
        "title": "ZCode: Clone Repository…",
        "icon": "$(cloud-download)"
      },
      {
        "command": "remoteHub.openRepository",
        "title": "Open Repository…",
        "icon": "$(repo-clone)"
      },
      {
        "command": "zcode.git.commit",
        "title": "ZCode: Commit",
        "icon": "$(check)"
      },
      {
        "command": "zcode.git.push",
        "title": "ZCode: Push",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "zcode.git.refresh",
        "title": "ZCode: Refresh SCM",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "zcode.git.refresh",
          "group": "navigation",
          "when": "scmProvider == zcode-git"
        },
        {
          "command": "zcode.git.push",
          "group": "navigation",
          "when": "scmProvider == zcode-git"
        },
        {
          "command": "zcode.git.openRepository",
          "group": "navigation",
          "when": "scmProvider == zcode-git"
        }
      ],
      "commandPalette": [
        {
          "command": "zcode.git.openRepository"
        },
        {
          "command": "zcode.git.clone"
        },
        {
          "command": "remoteHub.openRepository"
        }
      ]
    },
    "configuration": {
      "title": "ZCode",
      "properties": {
        "zcode.gitProxyUrl": {
          "type": "string",
          "default": "",
          "description": "isomorphic-git corsProxy base URL (empty = same-origin /git-proxy)"
        },
        "zcode.gitToken": {
          "type": "string",
          "default": "",
          "description": "HTTPS PAT for private clone/push (prefer session-only SPA token for secrets)"
        },
        "zcode.gitUsername": {
          "type": "string",
          "default": "git",
          "description": "Username for HTTPS git auth (GitHub accepts any non-empty with PAT as password)"
        },
        "zcode.authorName": {
          "type": "string",
          "default": "ZCode",
          "description": "Commit author name (browser git)"
        },
        "zcode.authorEmail": {
          "type": "string",
          "default": "zcode@localhost",
          "description": "Commit author email (browser git)"
        }
      }
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"process.exit(0)\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@zcode/browser-agent": "workspace:*",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}
