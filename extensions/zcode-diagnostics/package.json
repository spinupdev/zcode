{
  "name": "zcode-diagnostics",
  "displayName": "ZCode Diagnostics",
  "description": "Copy environment report for support / debugging (mode, capabilities, redacted URLs)",
  "version": "0.1.0",
  "publisher": "spinupdev",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "extensionKind": ["ui", "workspace"],
  "browser": "./dist/web/extension.js",
  "activationEvents": [
    "onCommand:zcode.diagnostics.copyReport",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "zcode.diagnostics.copyReport",
        "title": "ZCode: Copy Diagnostics Report"
      }
    ]
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"process.exit(0)\"",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}
