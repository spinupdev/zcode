{
  "name": "zcode-diagnostics",
  "displayName": "ZCode Diagnostics",
  "description": "Copy environment report for support / debugging",
  "version": "0.0.0",
  "publisher": "spinupdev",
  "private": true,
  "engines": {
    "vscode": "^1.129.0"
  },
  "categories": ["Other"],
  "browser": "./dist/web/extension.js",
  "main": "./dist/extension.js",
  "activationEvents": ["onCommand:zcode.diagnostics.copyReport"],
  "contributes": {
    "commands": [
      {
        "command": "zcode.diagnostics.copyReport",
        "title": "ZCode: Copy Diagnostics Report"
      }
    ]
  },
  "scripts": {
    "build": "node -e \"console.log('zcode-diagnostics: extension build stub (M2)')\"",
    "typecheck": "node -e \"process.exit(0)\"",
    "test": "node -e \"process.exit(0)\"",
    "clean": "rm -rf dist"
  }
}
