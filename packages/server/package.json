{
  "name": "@zcode/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "zcode-server": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.test.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist-test/**/*.test.js",
    "clean": "rm -rf dist dist-test *.tsbuildinfo"
  },
  "dependencies": {
    "@zcode/git-proxy": "workspace:*",
    "@zcode/protocol": "workspace:*"
  }
}
