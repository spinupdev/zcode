{
  "name": "@zcode/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "zcode": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.test.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist-test/**/*.test.js",
    "clean": "rm -rf dist dist-test *.tsbuildinfo"
  },
  "dependencies": {
    "@zcode/git-proxy": "workspace:*",
    "@zcode/server": "workspace:*"
  }
}
