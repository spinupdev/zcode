{
  "name": "@zcode/web",
  "version": "0.0.0",
  "private": true,
  "description": "ZCode browser workspace UI (clone/edit/commit via browser-agent + git-proxy)",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"process.exit(0)\"",
    "clean": "rm -rf dist",
    "dev": "node ../cli/dist/cli.js web --dir dist --port 5000"
  },
  "dependencies": {
    "@zcode/browser-agent": "workspace:*",
    "@zcode/shell": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.5"
  }
}
